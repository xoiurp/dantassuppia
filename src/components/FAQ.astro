---
interface Item { q: string; a: string }
interface Props { items: Item[] }
const { items } = Astro.props;
---

<div class="divide-y divide-navy-100 rounded-3xl border border-navy-100 bg-white">
  {items.map((it, i) => (
    <details class="group p-6 md:p-7" open={i === 0}>
      <summary class="flex cursor-pointer list-none items-start justify-between gap-6 text-left font-serif text-lg md:text-xl text-navy-900">
        {it.q}
        <span class="mt-1 inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-full border border-navy-200 text-navy-700 transition group-open:rotate-45 group-open:bg-navy-900 group-open:text-white">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"/></svg>
        </span>
      </summary>
      <p class="mt-4 text-ink/75 leading-relaxed">{it.a}</p>
    </details>
  ))}
</div>
