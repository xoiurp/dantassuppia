---
import Layout from "../../layouts/Layout.astro";
import AreaIcon from "../../components/AreaIcon.astro";
import { getCollection, render } from "astro:content";
import { site } from "../../lib/site";

export async function getStaticPaths() {
  const areas = await getCollection("areas");
  return areas.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const all = (await getCollection("areas")).sort((a, b) => a.data.order - b.data.order);
const others = all.filter((a) => a.id !== entry.id);
const idx = all.findIndex((a) => a.id === entry.id);
const next = all[(idx + 1) % all.length];
---

<Layout title={entry.data.title} description={entry.data.summary}>
  <section class="relative overflow-hidden bg-navy-950 text-white">
    <div class="absolute inset-0 opacity-30 [background:radial-gradient(circle_at_top_right,theme(colors.navy.700),transparent_55%)]"></div>
    <div class="container-x relative py-20 md:py-28">
      <a href="/areas-de-atuacao" class="inline-flex items-center gap-2 text-sm text-navy-200 hover:text-white">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Todas as áreas
      </a>
      <div class="mt-8 grid gap-8 lg:grid-cols-[auto_1fr] lg:items-center">
        <span class="inline-flex h-20 w-20 items-center justify-center rounded-3xl bg-white/5 ring-1 ring-white/10 text-gold-400">
          <AreaIcon name={entry.data.icon} class="h-10 w-10" />
        </span>
        <div>
          <p class="eyebrow text-gold-400">{entry.data.short} · Área de atuação</p>
          <h1 class="mt-3 text-4xl md:text-6xl font-semibold leading-tight text-white">{entry.data.title}</h1>
          <p class="mt-5 max-w-2xl text-lg text-navy-100">{entry.data.summary}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="container-x grid gap-14 py-16 md:py-20 lg:grid-cols-[1fr_320px]">
    <article class="prose-legal max-w-none">
      <Content />

      <div class="not-prose mt-12 rounded-3xl bg-navy-900 p-8 md:p-10 text-white">
        <p class="eyebrow text-gold-400">Próximo passo</p>
        <h3 class="mt-3 font-serif text-2xl md:text-3xl text-white">Precisa de orientação em {entry.data.title}?</h3>
        <p class="mt-3 text-navy-100 max-w-xl">Conte seu caso em poucas linhas e agendamos uma avaliação inicial. Resposta em até um dia útil.</p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a href="/contato" class="inline-flex items-center gap-2 rounded-full bg-gold-500 px-6 py-3 text-sm font-semibold text-navy-950 hover:bg-gold-400">Falar com advogado →</a>
          <a href={`https://wa.me/${site.whatsappE164}`} class="inline-flex items-center gap-2 rounded-full border border-white/30 px-6 py-3 text-sm font-medium text-white hover:bg-white/10">WhatsApp</a>
        </div>
      </div>
    </article>

    <aside class="space-y-6">
      <div class="sticky top-24 space-y-6">
        <div class="rounded-3xl border border-navy-100 bg-white p-6">
          <h4 class="text-xs font-semibold uppercase tracking-[0.18em] text-navy-900">Outras áreas</h4>
          <ul class="mt-5 space-y-3">
            {others.map((o) => (
              <li>
                <a href={`/areas-de-atuacao/${o.id}`} class="group flex items-center gap-3 rounded-xl p-2 -m-2 hover:bg-navy-50">
                  <span class="inline-flex h-9 w-9 items-center justify-center rounded-lg bg-navy-50 text-navy-700 group-hover:bg-navy-900 group-hover:text-gold-400 transition">
                    <AreaIcon name={o.data.icon} class="h-5 w-5" />
                  </span>
                  <span class="text-sm font-medium text-navy-900 group-hover:text-navy-700">{o.data.title}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div class="rounded-3xl border border-navy-100 bg-navy-50 p-6">
          <p class="eyebrow">Atendimento</p>
          <p class="mt-3 font-serif text-lg text-navy-900">{site.hours}</p>
          <ul class="mt-4 space-y-2 text-sm">
            <li><a href={`tel:${site.phoneE164}`} class="text-navy-700 hover:text-navy-900">{site.phone}</a></li>
            <li><a href={`mailto:${site.email}`} class="text-navy-700 hover:text-navy-900">{site.email}</a></li>
          </ul>
        </div>
      </div>
    </aside>
  </section>

  <section class="border-t border-navy-100 bg-navy-50">
    <div class="container-x py-12 md:flex md:items-center md:justify-between md:gap-8">
      <div>
        <p class="eyebrow">Continue explorando</p>
        <p class="mt-2 font-serif text-2xl text-navy-900">Próxima área: {next.data.title}</p>
      </div>
      <a href={`/areas-de-atuacao/${next.id}`} class="mt-4 btn-outline md:mt-0">
        Ver {next.data.short} →
      </a>
    </div>
  </section>
</Layout>
