---
import Layout from "../../layouts/Layout.astro";
import AreaIcon from "../../components/AreaIcon.astro";
import { getCollection } from "astro:content";

const areas = (await getCollection("areas")).sort((a, b) => a.data.order - b.data.order);
---

<Layout
  title="Áreas de Atuação"
  description="Conheça nossas áreas de atuação: Trabalhista, Empresarial, Ambiental, Civil, Agronegócio e Registral."
>
  <section class="bg-navy-50 border-b border-navy-100">
    <div class="container-x py-20 md:py-28">
      <p class="eyebrow">Práticas</p>
      <h1 class="mt-3 text-4xl md:text-5xl font-semibold">Áreas de Atuação</h1>
      <p class="mt-5 max-w-2xl text-lg text-ink/75">
        Atuação multidisciplinar com foco em prevenção, conformidade e resultado. Selecione uma área para conhecer os serviços oferecidos.
      </p>
    </div>
  </section>

  <section class="container-x py-20">
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {areas.map((a) => (
        <a
          href={`/areas-de-atuacao/${a.id}`}
          class="group flex flex-col rounded-2xl border border-navy-100 bg-white p-8 transition hover:-translate-y-1 hover:border-navy-300 hover:shadow-xl"
        >
          <span class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-navy-900 text-gold-400">
            <AreaIcon name={a.data.icon} />
          </span>
          <h2 class="mt-6 text-2xl font-semibold">{a.data.title}</h2>
          <p class="mt-3 flex-1 text-sm leading-relaxed text-ink/70">{a.data.summary}</p>
          <span class="mt-6 inline-flex items-center gap-2 text-sm font-medium text-navy-700 group-hover:text-navy-900">
            Saiba mais
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </span>
        </a>
      ))}
    </div>
  </section>
</Layout>
