---
import Layout from "../layouts/Layout.astro";
import { site } from "../lib/site";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  name: `Contato — ${site.name}`,
  url: `${site.url}/contato`,
};
---

<Layout
  title="Contato"
  description="Fale com o Dantas & Suppia Advogados. Atendemos em São Paulo (Av. Paulista) e Limeira. WhatsApp, telefone e email disponíveis."
  jsonLd={jsonLd}
>
  <section class="bg-navy-50 border-b border-navy-100">
    <div class="container-x py-20 md:py-24">
      <p class="eyebrow">Contato</p>
      <h1 class="mt-3 text-4xl md:text-5xl font-semibold">Vamos conversar sobre seu caso</h1>
      <p class="mt-5 max-w-2xl text-lg text-ink/75">
        Preencha o formulário ou utilize um dos canais abaixo. Respondemos em até um dia útil.
      </p>
    </div>
  </section>

  <section class="container-x grid gap-14 py-16 lg:grid-cols-[1.2fr_1fr]">
    <div>
      <form id="contact-form" class="space-y-5" novalidate>
        <div class="grid gap-5 sm:grid-cols-2">
          <label class="block">
            <span class="text-sm font-medium text-navy-900">Nome <span class="text-red-600">*</span></span>
            <input name="name" required maxlength="120" class="mt-2 w-full rounded-xl border border-navy-200 bg-white px-4 py-3 text-base focus:border-navy-500 focus:outline-none focus:ring-2 focus:ring-navy-200" />
          </label>
          <label class="block">
            <span class="text-sm font-medium text-navy-900">Email <span class="text-red-600">*</span></span>
            <input name="email" type="email" required maxlength="160" class="mt-2 w-full rounded-xl border border-navy-200 bg-white px-4 py-3 text-base focus:border-navy-500 focus:outline-none focus:ring-2 focus:ring-navy-200" />
          </label>
        </div>
        <div class="grid gap-5 sm:grid-cols-2">
          <label class="block">
            <span class="text-sm font-medium text-navy-900">Telefone</span>
            <input name="phone" maxlength="40" class="mt-2 w-full rounded-xl border border-navy-200 bg-white px-4 py-3 text-base focus:border-navy-500 focus:outline-none focus:ring-2 focus:ring-navy-200" />
          </label>
          <label class="block">
            <span class="text-sm font-medium text-navy-900">Assunto</span>
            <select name="subject" class="mt-2 w-full rounded-xl border border-navy-200 bg-white px-4 py-3 text-base focus:border-navy-500 focus:outline-none focus:ring-2 focus:ring-navy-200">
              <option>Consulta inicial</option>
              <option>Direito do Trabalho</option>
              <option>Direito Empresarial</option>
              <option>Direito Ambiental</option>
              <option>Direito Civil</option>
              <option>Agronegócio</option>
              <option>Direito Registral</option>
              <option>Outro assunto</option>
            </select>
          </label>
        </div>
        <label class="block">
          <span class="text-sm font-medium text-navy-900">Mensagem <span class="text-red-600">*</span></span>
          <textarea name="message" required maxlength="4000" rows="6" class="mt-2 w-full rounded-xl border border-navy-200 bg-white px-4 py-3 text-base focus:border-navy-500 focus:outline-none focus:ring-2 focus:ring-navy-200"></textarea>
        </label>

        <input type="text" name="website" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />

        <p class="text-xs text-ink/60">
          Ao enviar, você concorda em ser contatado por nossa equipe a respeito de sua solicitação.
        </p>

        <button type="submit" class="btn-primary">
          <span data-label>Enviar mensagem</span>
        </button>

        <p id="form-feedback" role="status" aria-live="polite" class="hidden text-sm"></p>
      </form>
    </div>

    <aside class="space-y-5">
      <div class="rounded-2xl border border-navy-100 bg-white p-6">
        <h3 class="font-serif text-xl text-navy-900">Canais diretos</h3>
        <ul class="mt-4 space-y-3 text-sm">
          <li><a href={`tel:${site.phoneE164}`} class="text-navy-700 hover:text-navy-900">📞 {site.phone}</a></li>
          <li><a href={`https://wa.me/${site.whatsappE164}`} class="text-navy-700 hover:text-navy-900">💬 WhatsApp {site.whatsapp}</a></li>
          <li><a href={`mailto:${site.email}`} class="text-navy-700 hover:text-navy-900">✉ {site.email}</a></li>
        </ul>
        <p class="mt-4 text-xs text-ink/60">{site.hours}</p>
      </div>

      {site.addresses.map((a) => (
        <div class="rounded-2xl border border-navy-100 bg-white p-6">
          <p class="eyebrow">Escritório · {a.label}</p>
          <p class="mt-2 font-serif text-lg text-navy-900">{a.street}</p>
          <p class="text-sm text-ink/70">{a.district} — {a.city}/{a.state}</p>
          <p class="text-sm text-ink/70">CEP {a.zip}</p>
          <a href={a.mapsUrl} target="_blank" rel="noopener" class="mt-3 inline-block text-sm text-navy-700 hover:text-navy-900">Abrir no Google Maps →</a>
        </div>
      ))}
    </aside>
  </section>
</Layout>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  const feedback = document.getElementById("form-feedback") as HTMLParagraphElement | null;
  const btnLabel = form?.querySelector("[data-label]") as HTMLElement | null;

  function setFeedback(msg: string, ok: boolean) {
    if (!feedback) return;
    feedback.hidden = false;
    feedback.classList.remove("hidden");
    feedback.textContent = msg;
    feedback.className = `text-sm ${ok ? "text-emerald-700" : "text-red-700"}`;
  }

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!form || !btnLabel) return;
    const original = btnLabel.textContent;
    btnLabel.textContent = "Enviando...";
    (form.querySelector("button[type=submit]") as HTMLButtonElement).disabled = true;

    try {
      const res = await fetch("/api/contact", {
        method: "POST",
        body: new FormData(form),
      });
      const json = await res.json().catch(() => ({}));
      if (res.ok && json.ok) {
        setFeedback("Mensagem enviada! Em breve entraremos em contato.", true);
        form.reset();
      } else {
        setFeedback(json.error ?? "Não foi possível enviar. Tente novamente.", false);
      }
    } catch {
      setFeedback("Erro de conexão. Verifique e tente novamente.", false);
    } finally {
      btnLabel.textContent = original ?? "Enviar mensagem";
      (form.querySelector("button[type=submit]") as HTMLButtonElement).disabled = false;
    }
  });
</script>
